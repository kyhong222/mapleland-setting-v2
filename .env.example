# ── 프론트엔드 (Vite, VITE_ 접두사만 번들에 노출됨) ──
# 문의하기 프록시 엔드포인트. 같은 도메인에 함수가 있으면 비워두면 됨(기본: /api/feedback).
# GitHub Pages처럼 함수가 다른 도메인에 있으면 전체 URL 지정:
#   VITE_FEEDBACK_ENDPOINT=https://your-app.vercel.app/api/feedback
VITE_FEEDBACK_ENDPOINT=

# ── 서버리스 함수 전용 (절대 VITE_ 접두사 X · 브라우저에 노출 금지) ──
# 아래 값들은 로컬 .env가 아니라 배포 플랫폼(Vercel 등)의 환경변수에 넣으세요.
# GITHUB_TOKEN=github_pat_xxx      # (필수) Fine-grained PAT · 해당 레포 Issues: Read/Write
# GITHUB_OWNER=kyhong222           # (선택)
# GITHUB_REPO=mapleland-setting-v2 # (선택)
# ALLOWED_ORIGIN=https://kyhong222.github.io  # (선택) CORS 허용 출처
